# .env.example — copy to .env and fill in real values
# NEVER commit the real .env file

# ─── Walmart SSO (Azure AD) ──────────────────────────────────────────
WALMART_TENANT_ID=3cbcc3d3-094d-4006-9849-0d11d61f484d
WALMART_CLIENT_ID=cadowl-app
WALMART_CLIENT_SECRET=        # Get from Azure AD app registration
WALMART_REDIRECT_URI=http://localhost:9010/auth/callback
CADOWL_DEV_MODE=true          # Set false in production
CADOWL_DEV_USER=dev.user@walmart.com

# ─── Lifecycle Data ──────────────────────────────────────────────────
CADOWL_DATA_DIR=./data/lifecycle
CADOWL_JSONDB_DIR=./data/jsondb

# ─── API ─────────────────────────────────────────────────────────────
API_PORT=9010
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_ENV=development           # development | staging | production

# ─── Database (Phase 1.1+) ───────────────────────────────────────────
DATABASE_URL=postgresql://cadowl:cadowl@localhost:5432/cadowl
REDIS_URL=redis://localhost:6379/0

# ─── Doris ───────────────────────────────────────────────────────────
DORIS_API_URL=https://doris.walmart.com/api/v1
DORIS_API_KEY=                # Get from Doris admin

# ─── Saone ───────────────────────────────────────────────────────────
SAONE_API_URL=https://saone.walmart.com/api/v1
SAONE_API_KEY=                # Get from Saone admin

# ─── SA Grafana ──────────────────────────────────────────────────────
GRAFANA_URL=https://sagrafana.sbox.walmart.com
GRAFANA_API_KEY=              # Generate in Grafana → Settings → API Keys

# ─── Element AI (LLM) ────────────────────────────────────────────────
ELEMENT_API_URL=https://element.walmart.com/api/v1
ELEMENT_API_KEY=

# ─── GitHub (for auto-commit / project tracking) ─────────────────────
GITHUB_TOKEN=                 # PAT with repo:write scope
GITHUB_REPO=vn59j7j/CadOwl

# ─── Storage (object store for uploads / exports) ────────────────────
STORAGE_BACKEND=local         # local | s3 | azure
STORAGE_LOCAL_PATH=./data/storage
S3_BUCKET=
S3_REGION=
AZURE_CONTAINER=

# ─── Feature flags ───────────────────────────────────────────────────
FEATURE_ML_AUTODESIGN=true
FEATURE_GIS=true
FEATURE_SAONE_LIVE=false      # requires production Saone credentials
FEATURE_GRAFANA_LIVE=false    # requires production Grafana credentials
FEATURE_AXIS_IMPORT=true

# ─── Observability ───────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091
