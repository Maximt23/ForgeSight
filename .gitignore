# ─────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────
# Secrets — NEVER COMMIT
# ─────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.secret
secrets/
credentials/
*credentials*.json
*service_account*.json
api_keys.txt
*API*KEY*

# ─────────────────────────────────────────────────────────────────────
# AutoCAD intermediate / output files
# ─────────────────────────────────────────────────────────────────────
*.bak
*.dwl
*.dwl2
*.tmp
*_recover.dwg
*.dxf
*.dwg
!data/fixtures/**/*.dxf
!data/fixtures/**/*.dwg

# ─────────────────────────────────────────────────────────────────────
# Data files — DO NOT COMMIT customer/store data
# ─────────────────────────────────────────────────────────────────────
*.csv
*.xlsx
*.xls
*_log.txt
Input/
Output/
Output/*.json
exports/
uploads/
photos/
videos/
training_data/

# Allow schema and fixture data
!data/schemas/**
!data/fixtures/**
!data/jsondb/.gitkeep
!docs/**/*.csv

# ─────────────────────────────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
cadowl_memory.db
puppy_memory.db

# ─────────────────────────────────────────────────────────────────────
