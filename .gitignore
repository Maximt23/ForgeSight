# ─────────────────────────────────────────────────────────────────────
.doris_cache.json
.saone_device_mapping.json
.grafana_cache.json
.osm_cache/

# ─────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────
*.log
logs/
watcher.log
*.log.gz

# ─────────────────────────────────────────────────────────────────────
